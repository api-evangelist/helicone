{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ProviderMetrics",
  "title": "ProviderMetrics",
  "properties": {
    "providerName": {
      "type": "string"
    },
    "metrics": {
      "allOf": [
        {
          "$ref": "#/components/schemas/MetricsData"
        },
        {
          "properties": {
            "timeSeriesData": {
              "items": {
                "$ref": "#/components/schemas/TimeSeriesDataPoint"
              },
              "type": "array"
            }
          },
          "required": [
            "timeSeriesData"
          ],
          "type": "object"
        }
      ]
    }
  },
  "required": [
    "providerName",
    "metrics"
  ],
  "type": "object",
  "additionalProperties": false
}